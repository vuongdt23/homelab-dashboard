{
  "name": "homelab-dashboard",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build -w packages/shared && npm run build -w packages/web && npm run build -w packages/server",
    "test": "npm run test -w packages/server",
    "dev:server": "npm run dev -w packages/server",
    "dev:web": "npm run dev -w packages/web"
  }
}
